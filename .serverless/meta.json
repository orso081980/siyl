    "serviceRawFile": "service: multi-symfony-api\n\nprovider:\n  name: aws\n  region: eu-west-1   # Ireland — closest to Neon eu-west-2 (London)\n  runtime: provided.al2023\n  environment:\n    APP_ENV: prod\n    APP_DEBUG: \"0\"\n    APP_SECRET: ${ssm:/multi-symfony/APP_SECRET}\n    DATABASE_URL: ${ssm:/multi-symfony/DATABASE_URL}\n    JWT_SECRET_KEY: /var/task/config/jwt/private.pem\n    JWT_PUBLIC_KEY: /var/task/config/jwt/public.pem\n    JWT_PASSPHRASE: ${ssm:/multi-symfony/JWT_PASSPHRASE}\n    CORS_ALLOW_ORIGIN: ${ssm:/multi-symfony/CORS_ALLOW_ORIGIN}\n    DEFAULT_URI: ${ssm:/multi-symfony/DEFAULT_URI}\n    # base cache.yaml references this env var; we override the adapter to\n    # cache.adapter.array in prod, so no Redis connection is ever opened —\n    # but the env var must exist or Symfony throws EnvNotFoundException.\n    REDIS_URL: redis://localhost:6379\n\nfunctions:\n  # Bref 3: set runtime directly; plugin auto-injects the FPM layer\n  web:\n    handler: public/index.php\n    runtime: php-84-fpm\n    timeout: 28          # API Gateway HTTP API hard max is 29 s\n    memorySize: 512\n    events:\n      - httpApi:\n          path: /{proxy+}\n          method: ANY\n      - httpApi:\n          path: /\n          method: ANY\n\n  # Bref 3 console runner\n  console:\n    handler: bin/console\n    runtime: php-84-console\n    timeout: 120\n\nplugins:\n  - ./vendor/bref/bref\n\npackage:\n  patterns:\n    - '!node_modules/**'\n    - '!tests/**'\n    - '!docker/**'\n    - '!docs/**'\n    - '!.git/**'\n    - '!compose*.yaml'\n    - '!*.md'\n    - '!var/cache/**'\n    - '!var/log/**'\n",
